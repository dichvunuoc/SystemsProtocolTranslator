{
  "name": "systemsprotocoltranslator",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "mock:modbus:a": "STATION_PROFILE=full MODBUS_PORT=5020 tsx mock-servers/modbus-mock/server.ts",
    "mock:modbus:b": "STATION_PROFILE=minimal MODBUS_PORT=5021 tsx mock-servers/modbus-mock/server.ts",
    "mock:opcua:a": "PUMP_NODES=PUMP_01.Command,PUMP_02.Command OPCUA_PORT=4840 tsx mock-servers/opcua-mock/server.ts",
    "mock:opcua:b": "PUMP_NODES=PUMP_03.Command OPCUA_PORT=4841 tsx mock-servers/opcua-mock/server.ts",
    "dev:local": "DEVICE_MAP_PATH=src/config/device-map.local.json LOG_LEVEL=info tsx src/index.ts | npx pino-pretty",
    "dev:real": "DEVICE_MAP_PATH=src/config/device-map.real.json LOG_LEVEL=info tsx src/index.ts | npx pino-pretty"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "jsmodbus": "^4.0.10",
    "modbus-serial": "^8.0.23",
    "node-opcua": "^2.164.2",
    "pino": "^10.3.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
